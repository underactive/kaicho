{
  "name": "@kaicho/dashboard",
  "version": "0.1.0",
  "description": "Read-only web dashboard for Kaicho scan/sweep data",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/server/index.js",
  "types": "./dist/server/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    }
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch src/server/main.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/main.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "preview": "tsx src/server/main.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "chart.js": "^4.5.1",
    "hono": "^4.7.0",
    "vue-chartjs": "^5.3.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@vitejs/plugin-vue": "^5.2.0",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  }
}
