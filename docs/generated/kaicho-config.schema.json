{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kaicho-config",
  "title": "KaichoConfig",
  "description": "Per-repo configuration file (kaicho.config.json). All fields are optional — CLI flags override these values.",
  "type": "object",
  "properties": {
    "agent": {
      "type": "string",
      "description": "Default agent to use (omit to run all available)"
    },
    "task": {
      "type": "string",
      "enum": ["security", "qa", "docs"],
      "description": "Default task type (default: security)"
    },
    "timeout": {
      "type": "integer",
      "minimum": 1000,
      "description": "Agent timeout in milliseconds (default: 300000)"
    },
    "scope": {
      "type": "string",
      "description": "Comma-separated directory paths to limit scan scope (e.g. 'src,lib')"
    },
    "files": {
      "type": "string",
      "description": "Comma-separated file glob patterns (e.g. '*.ts,*.js')"
    },
    "minSeverity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low", "info"],
      "description": "Minimum severity to include in output"
    },
    "models": {
      "type": "object",
      "description": "Per-agent model overrides (e.g. {\"codex\": \"o4-mini\", \"gemini\": \"gemini-2.5-pro\"})",
      "additionalProperties": { "type": "string" }
    },
    "reviewer": {
      "type": "string",
      "description": "Default agent for --validate reviews (e.g. \"claude\")"
    },
    "retention": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of scan runs to keep per agent+task (default: 3). Older runs are pruned automatically."
    }
  },
  "additionalProperties": false
}
