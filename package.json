{
  "name": "kaicho",
  "version": "0.1.1",
  "description": "Run AI coding agents against repos and collect structured suggestions",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "kaicho": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "npm run build -w @kaicho/dashboard && tsc",
    "build:cli": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kaicho/dashboard": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "commander": "^13.0.0",
    "execa": "^9.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
